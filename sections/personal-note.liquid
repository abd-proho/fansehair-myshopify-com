{{- 'section-personal-note.css' | asset_url | stylesheet_tag -}}

{%- style -%}
  #shopify-section-{{ section.id }} {
    --section-spacing-top: calc(var(--section-spacing-unit-size) * {{ section.settings.spacing_top }});
    --section-spacing-bottom: calc(var(--section-spacing-unit-size) * {{ section.settings.spacing_bottom }});
    --section-min-height: {{ section.settings.section_min_height }}vh;
    --content-max-width: {{ section.settings.content_max_width }}px;
    --content-position-x: {{ section.settings.content_position_horizontal }}%;
    --content-position-y: {{ section.settings.content_position_vertical }}%;
    --gradient-direction: {{ section.settings.gradient_direction | default: '180deg' }};
    --overlay-gradient-direction: {{ section.settings.overlay_gradient_direction | default: '180deg' }};
  }

  {%- for block in section.blocks -%}
    {%- if block.type == 'floating_image' -%}
      #Block-{{ block.id }} {
        --floating-image-x: {{ block.settings.position_horizontal }}%;
        --floating-image-y: {{ block.settings.position_vertical }}%;
        --floating-image-x-mobile: {{ block.settings.position_horizontal_mobile }}%;
        --floating-image-y-mobile: {{ block.settings.position_vertical_mobile }}%;
        --floating-image-width: {{ block.settings.image_width }}px;
        --floating-image-width-mobile: {{ block.settings.image_width_mobile }}px;
        --floating-image-rotation: {{ block.settings.image_rotation }}deg;
        --floating-image-rotation-mobile: {{ block.settings.image_rotation_mobile }}deg;
      }
    {%- endif -%}
  {%- endfor -%}

  .section-personal-note {
    background: linear-gradient({{ section.settings.gradient_direction | default: '180deg' }}, rgba(230, 246, 255, 1) 0%, rgba(230, 246, 255, 0) 100%);
  }
{%- endstyle -%}

<div class="container max-w-fluid personal-note color-{{ section.settings.color_scheme }} gradient">
  {%- comment -%} Background Images {%- endcomment -%}
  <div class="personal-note__background{% if section.settings.background_overlay %} personal-note__background--overlay{% endif %}">
    {%- if section.settings.background_image_desktop != blank -%}
      <div class="personal-note__background-media personal-note__background-media--desktop{% if section.settings.background_image_mobile != blank %} small-hide{% endif %}">
        {%- assign desktop_image = section.settings.background_image_desktop -%}
        <img
          src="{{ desktop_image | image_url: width: 2400 }}"
          srcset="{{ desktop_image | image_url: width: 1200 }} 1200w,
                  {{ desktop_image | image_url: width: 1800 }} 1800w,
                  {{ desktop_image | image_url: width: 2400 }} 2400w"
          sizes="100vw"
          alt="{{ desktop_image.alt | default: 'Background image' | escape }}"
          loading="lazy"
          width="{{ desktop_image.width }}"
          height="{{ desktop_image.height }}"
          class="personal-note__background-image"
        >
      </div>
    {%- else -%}
      <div class="personal-note__background-placeholder{% if section.settings.background_image_mobile != blank %} small-hide{% endif %}"></div>
    {%- endif -%}

    {%- if section.settings.background_image_mobile != blank -%}
      <div class="personal-note__background-media personal-note__background-media--mobile small-up-hide">
        {%- assign mobile_image = section.settings.background_image_mobile -%}
        <img
          src="{{ mobile_image | image_url: width: 800 }}"
          srcset="{{ mobile_image | image_url: width: 400 }} 400w,
                  {{ mobile_image | image_url: width: 600 }} 600w,
                  {{ mobile_image | image_url: width: 800 }} 800w"
          sizes="100vw"
          alt="{{ mobile_image.alt | default: 'Background image' | escape }}"
          loading="lazy"
          width="{{ mobile_image.width }}"
          height="{{ mobile_image.height }}"
          class="personal-note__background-image"
        >
      </div>
    {%- endif -%}
  </div>

  {%- comment -%} Floating Images {%- endcomment -%}
  <div class="personal-note__floating-images">
    {%- for block in section.blocks -%}
      {%- if block.type == 'floating_image' -%}
        <div 
          id="Block-{{ block.id }}"
          class="personal-note__floating-image{% if block.settings.enable_animation %} personal-note__floating-image--animated{% endif %}{% if block.settings.hide_on_mobile %} small-hide{% endif %}{% if block.settings.hide_on_desktop %} small-up-hide{% endif %}"
          {{ block.shopify_attributes }}
        >
          {%- if block.settings.image != blank -%}
            {%- render 'image', image: block.settings.image, width: 600, alt: block.settings.image.alt | default: 'Decorative image' -%}
          {%- else -%}
            <div class="personal-note__floating-image-placeholder">
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>

  {%- comment -%} Content {%- endcomment -%}
  <div class="personal-note__container container {{ section.settings.section_width }}">
    <div class="personal-note__content text-{{ section.settings.content_alignment }}">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'subheading' -%}
            {%- if block.settings.text != blank -%}
              <p class="personal-note__subheading {{ block.settings.text_style }}" {{ block.shopify_attributes }}>
                {{ block.settings.text }}
              </p>
            {%- endif -%}

          {%- when 'heading' -%}
            {%- if block.settings.heading != blank -%}
              <{{ block.settings.heading_tag }} class="personal-note__heading {{ block.settings.heading_size }}" {{ block.shopify_attributes }}>
                {{ block.settings.heading }}
              </{{ block.settings.heading_tag }}>
            {%- endif -%}

          {%- when 'richtext' -%}
            {%- if block.settings.text != blank -%}
              <div class="personal-note__richtext entry {{ block.settings.text_style }}" {{ block.shopify_attributes }}>
                {{ block.settings.text }}
              </div>
            {%- endif -%}

          {%- when 'signature' -%}
            <div class="personal-note__signature" {{ block.shopify_attributes }}>
              {%- if block.settings.signature_image != blank -%}
                <div class="personal-note__signature-image" style="max-width: {{ block.settings.signature_width }}px;">
                  {%- render 'image', image: block.settings.signature_image, width: 400, alt: block.settings.signature_image.alt | default: 'Signature' -%}
                </div>
              {%- endif -%}
              {%- if block.settings.signature_text != blank -%}
                <span class="personal-note__signature-text {{ block.settings.signature_style }}">
                  {{ block.settings.signature_text }}
                </span>
              {%- endif -%}
            </div>

          {%- when 'button' -%}
            {%- if block.settings.button_label != blank -%}
              <div class="personal-note__button" {{ block.shopify_attributes }}>
                {%- render 'button',
                  type: 'link',
                  class: 'button',
                  button_style: block.settings.button_style,
                  value: block.settings.button_label,
                  href: block.settings.button_link
                -%}
              </div>
            {%- endif -%}

          {%- when 'spacer' -%}
            <div class="personal-note__spacer" style="height: {{ block.settings.spacing_height }}px;" {{ block.shopify_attributes }}></div>

        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
</div>

