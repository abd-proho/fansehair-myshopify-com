{%- style -%}
  #shopify-section-{{ section.id }} > div {
    padding-block-start: calc(var(--section-spacing-unit-size) * {{ section.settings.spacing_top }});
    padding-block-end: calc(var(--section-spacing-unit-size) * {{ section.settings.spacing_bottom }});
  }

  /* KEEP PRODUCT CARDS SAME SIZE ON LARGE SCREENS */
  #shopify-section-{{ section.id }} .product-card,
  #shopify-section-{{ section.id }} .swiper-slide {
    width: 390px !important;
    max-width: 390px !important;
  }

  /* tablet */
  @media screen and (max-width: 1200px) {
    #shopify-section-{{ section.id }} .product-card,
    #shopify-section-{{ section.id }} .swiper-slide {
      width: 31vw !important;
      max-width: 390px !important;
    }
  }

  /* mobile */
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .product-card,
    #shopify-section-{{ section.id }} .swiper-slide {
      width: {{ section.settings.product_card_width | times: 0.5 }}px !important;
      max-width: 100% !important;
    }
  }

  /* TITLE / PRICE FONT */
  #shopify-section-{{ section.id }} .product-card__title,
  #shopify-section-{{ section.id }} .price {
    font-family: var(--font-{{ section.settings.product_card_title_font }}-family);
    text-transform: {{ section.settings.product_card_title_transform }};
  }

  /* IMAGE AREA */
  #shopify-section-{{ section.id }} .product-card__image-wrapper {
    background: #efefef;
    padding: 18px;
  }

  /* PRODUCT INFO */
  #shopify-section-{{ section.id }} .product-card__info {
    padding: 16px 18px 18px;
    position: relative;
  }

  /* TITLE */
  #shopify-section-{{ section.id }} .product-card__title {
    font-size: 18px;
    font-weight: 600;
    margin-bottom: 6px;
  }

  /* SUBTEXT UNDER TITLE */
  #shopify-section-{{ section.id }} .product-card__vendor,
  #shopify-section-{{ section.id }} .product-card__description,
  #shopify-section-{{ section.id }} .short-description {
    display: block !important;
    font-size: 14px;
    color: #555;
    margin-bottom: 12px;
    text-transform: none;
  }

  /* 5 BLUE STARS RIGHT SIDE */
  #shopify-section-{{ section.id }} .product-card__rating,
  #shopify-section-{{ section.id }} .jdgm-prev-badge {
    position: absolute;
    right: 18px;
    top: 18px;
    font-size: 16px;
  }

  #shopify-section-{{ section.id }} .jdgm-star,
  #shopify-section-{{ section.id }} .jdgm-prev-badge__star {
    color: #0b36ff !important;
    opacity: 1 !important;
  }

  /* FORCE 5 FILLED STARS */
  #shopify-section-{{ section.id }} .jdgm-prev-badge[data-average-rating] .jdgm-star {
    color: #0b36ff !important;
  }

  /* PRICE / BUTTON ROW */
  #shopify-section-{{ section.id }} .product-card__bottom,
  #shopify-section-{{ section.id }} .product-card__actions {
    border-top: 1px solid #111;
    padding-top: 14px;
    margin-top: 14px;
  }

  /* NEW BADGE ON ALL PRODUCTS */
  #shopify-section-{{ section.id }} .product-card {
    position: relative;
  }

  #shopify-section-{{ section.id }} .product-card:before {
    content: "NEW";
    position: absolute;
    top: 14px;
    left: 14px;
    background: #d7a13d;
    color: #fff;
    font-size: 12px;
    letter-spacing: .08em;
    padding: 7px 10px;
    z-index: 9;
    font-weight: 600;
  }
{%- endstyle -%}