{%- liquid
  assign padding_horizontal = section.settings.padding_horizontal
  assign padding_horizontal_mobile = section.settings.padding_horizontal_mobile
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign margin_top = section.settings.margin_top
  assign margin_bottom = section.settings.margin_bottom
  assign background_color = section.settings.background_color
  assign full_width = section.settings.full_width
  assign content_width = section.settings.content_width

  assign heading = section.settings.heading
  assign heading_size = section.settings.heading_size
  assign heading_size_mobile = section.settings.heading_size_mobile
  assign heading_color = section.settings.heading_color

  assign subheading = section.settings.subheading
  assign subheading_size = section.settings.subheading_size
  assign subheading_size_mobile = section.settings.subheading_size_mobile
  assign subheading_color = section.settings.subheading_color

  assign step_size = section.settings.step_size
  assign step_size_mobile = section.settings.step_size_mobile
  assign step_color = section.settings.step_color

  assign text_size = section.settings.text_size
  assign text_size_mobile = section.settings.text_size_mobile
  assign text_color = section.settings.text_color

  assign slider_gap = section.settings.slider_gap
  assign slider_gap_mobile = section.settings.slider_gap_mobile
  assign slider_mt = section.settings.slider_mt

  assign image_radius = section.settings.image_radius
  assign image_border_thickness = section.settings.image_border_thickness
  assign image_border_color = section.settings.image_border_color

  assign ba_mt = section.settings.ba_mt
  assign ba_gap = section.settings.ba_gap
  assign ba_gap_mobile = section.settings.ba_gap_mobile
  assign ba_border_color = section.settings.ba_border_color
  assign ba_border_thickness = section.settings.ba_border_thickness
  assign ba_label_color = section.settings.ba_label_color
-%}

{%- style -%}
  @font-face {
    font-family: 'Thursday Morning';
    src: url('{{ "ThursdayMorningMedium.woff2" | asset_url }}') format('woff2'),
         url('{{ "ThursdayMorning.woff2" | asset_url }}') format('woff2'),
         url('{{ "ThursdayMorningMedium.woff2" | asset_url }}') format('woff2');
    font-weight: normal;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: 'CitadelScript';
    src: url('{{ "CitadelScriptStd.otf" | asset_url }}') format('opentype');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  .section-{{ section.id }} {
    margin-top: {{ margin_top | times: 0.75 | round: 0 }}px;
    margin-bottom: {{ margin_bottom | times: 0.75 | round: 0 }}px;
    background: linear-gradient(to bottom, #d4e8f2 0%, #ffffff 70%);
  }

  .section-{{ section.id }}-settings {
    margin: 0 auto;
    width: 100%;
    height: 100%;
    padding-top: 0;
    padding-bottom: {{ padding_bottom | times: 0.75 | round: 0 }}px;
    padding-left: {{ padding_horizontal_mobile }}rem;
    padding-right: {{ padding_horizontal_mobile }}rem;
  }

  .how-to-use-header-{{ section.id }} {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin-bottom: 0;
    flex-wrap: wrap;
    border-bottom: 0.4px solid #00000033;
  }

  .how-to-use-header-inner-{{ section.id }} {
    position: relative;
    padding-bottom: 0.4rem;
    display: flex;
    align-items: baseline;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .how-to-use-header-inner-{{ section.id }}::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background-color: {{ heading_color }};
  }

  .how-to-use-heading-{{ section.id }} {
    margin: 0;
    font-size: {{ heading_size_mobile }}px;
    color: {{ heading_color }};
    line-height: 1.2;
    text-transform: uppercase;
    font-weight: 400;
    position: relative;
    padding-bottom: 0.25rem;
  }

  .how-to-use-subheading-{{ section.id }} {
    margin: 0;
    font-family: 'CitadelScript', 'Citadel Script Std', 'Brush Script MT', cursive;
    font-size: {{ subheading_size_mobile }}px;
    color: {{ subheading_color }};
    line-height: 1.2;
    font-weight: normal;
  }

  .how-to-use-underline-{{ section.id }} {
    display: block;
    width: calc(100% + 1rem);
    height: 2px;
    background-color: {{ heading_color }};
    margin-top: 0.5rem;
    margin-bottom: 0;
  }

  .how-to-use-grid-{{ section.id }} {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: {{ slider_gap_mobile }}px;
    margin-top: {{ slider_mt | times: 0.75 | round: 0 }}px;
  }

  .how-to-use-card-{{ section.id }} {
    display: flex;
    flex-direction: column;
    text-align: left;
  }

  .how-to-use-media-{{ section.id }} {
    position: relative;
    width: 100%;
    aspect-ratio: 0 / 1;
    overflow: hidden;
    border-radius: {{ image_radius }}px;
    border: {{ image_border_thickness }}px solid {{ image_border_color }};
    background-color: #ddd;
  }

  .how-to-use-media-{{ section.id }} img,
  .how-to-use-media-{{ section.id }} video {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  .how-to-use-media-{{ section.id }} video {
    position: absolute;
    top: 0;
    left: 0;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .how-to-use-media-{{ section.id }}.video-playing video {
    opacity: 1;
  }

  .how-to-use-media-{{ section.id }} .placeholder-svg {
    width: 100%;
    height: 100%;
  }

  .how-to-use-step-{{ section.id }} {
    margin: 0;
    margin-top: 24px;
    font-family: 'Thursday Morning', cursive;
    font-size: {{ step_size_mobile }}px;
    color: {{ step_color }};
    line-height: 1.3;
    font-weight: normal;
    text-underline-offset: 1px;
    text-align: center;
  }

  .how-to-use-text-{{ section.id }} {
    margin: 0;
    margin-top: 6px;
    font-size: {{ text_size_mobile }}px;
    color: {{ text_color }};
    line-height: 1.4;
    font-weight: 400;
    max-width: 60%;
    margin: auto;
    margin-bottom: 24px;
  }

  @media(min-width: 768px) {
    .how-to-use-grid-{{ section.id }} {
      grid-template-columns: repeat(4, 1fr);
      gap: {{ slider_gap }}px;
      margin-top: {{ slider_mt }}px;
    }
  }

  /* Before / After grid */
  .before-after-grid-{{ section.id }} {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: {{ ba_gap_mobile }}px;
    margin-top: {{ ba_mt | times: 0.75 | round: 0 }}px;
  }

  .before-after-pair-{{ section.id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    overflow: hidden;
  }

  .before-after-item-{{ section.id }} {
    position: relative;
    aspect-ratio: 1 / 2;
    overflow: hidden;
  }

  .before-after-item-{{ section.id }} img,
  .before-after-item-{{ section.id }} .placeholder-svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .before-after-label-{{ section.id }} {
    position: absolute;
    top: 8px;
    left: 8px;
    font-size: 11px;
    color: {{ ba_label_color }};
    text-transform: lowercase;
    letter-spacing: 0.05em;
    line-height: 1;
    z-index: 1;
    background: rgba(255,255,255,0.7);
    padding: 2px 5px;
    border-radius: 2px;
  }

  @media(min-width: 768px) {
    .before-after-grid-{{ section.id }} {
      grid-template-columns: repeat(3, 1fr);
      gap: {{ ba_gap }}px;
      margin-top: {{ ba_mt }}px;
    }
  }

  @media(min-width: 1024px) {
    .section-{{ section.id }} {
      margin-top: {{ margin_top }}px;
      margin-bottom: {{ margin_bottom }}px;
    }

    .section-{{ section.id }}-settings {
      padding-top: {{ padding_top }}px;
      padding-bottom: {{ padding_bottom }}px;
      padding-left: {{ padding_horizontal }}rem;
      padding-right: {{ padding_horizontal }}rem;
    }

    .how-to-use-heading-{{ section.id }} {
      font-size: {{ heading_size }}px;
    }

    .how-to-use-subheading-{{ section.id }} {
      font-size: {{ subheading_size }}px;
    }

    .how-to-use-step-{{ section.id }} {
      font-size: {{ step_size }}px;
    }

    .how-to-use-text-{{ section.id }} {
      font-size: {{ text_size }}px;
      max-width: 50%;
    }
  }
{%- endstyle -%}

{% unless full_width %}
  <style>
    .section-{{ section.id }}-settings {
      max-width: {{ content_width }}px;
    }
  </style>
{% endunless %}

<div class="container max-w-fluid section-{{ section.id }}">
  <div class="section-{{ section.id }}-settings">
    <div class="how-to-use-header-{{ section.id }}">
      <div class="how-to-use-header-inner-{{ section.id }}">
        {% if heading != blank %}
          <h2 class="how-to-use-heading-{{ section.id }} section-heading">{{ heading }}</h2>
        {% endif %}
        {% if subheading != blank %}
          <span class="how-to-use-subheading-{{ section.id }}">{{ subheading }}</span>
        {% endif %}
      </div>
    </div>
    <div class="how-to-use-underline-{{ section.id }}"></div>

    <div class="how-to-use-grid-{{ section.id }}">
      {% for block in section.blocks %}
        <div class="how-to-use-card-{{ section.id }}" {{ block.shopify_attributes }}>
          <div class="how-to-use-media-{{ section.id }}" data-has-video="{% if block.settings.video != blank %}true{% else %}false{% endif %}">
            {% if block.settings.poster != blank %}
              <img
                src="{{ block.settings.poster | image_url: width: 600 }}"
                alt="{{ block.settings.poster.alt | default: block.settings.step_label }}"
                loading="lazy"
                width="600"
                height="600"
              >
            {% else %}
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
            {% endif %}
            
            {% if block.settings.video != blank %}
              <video
                src="{{ block.settings.video.sources[1].url }}"
                muted
                playsinline
                loop
                preload="none"
              ></video>
            {% endif %}
          </div>
          {% if block.settings.step_label != blank %}
            <p class="how-to-use-step-{{ section.id }}">{{ block.settings.step_label }}</p>
          {% endif %}
          {% if block.settings.description != blank %}
            <p class="how-to-use-text-{{ section.id }}">{{ block.settings.description }}</p>
          {% endif %}
        </div>
      {% endfor %}
    </div>

    {%- assign ba_has_content = false -%}
    {%- if section.settings.ba_before_1 != blank or section.settings.ba_after_1 != blank
        or section.settings.ba_before_2 != blank or section.settings.ba_after_2 != blank
        or section.settings.ba_before_3 != blank or section.settings.ba_after_3 != blank -%}
      {%- assign ba_has_content = true -%}
    {%- endif -%}

    {%- if ba_has_content -%}
      <div class="before-after-grid-{{ section.id }}">
        {%- for i in (1..3) -%}
          {%- assign ba_before = 'ba_before_' | append: i -%}
          {%- assign ba_after  = 'ba_after_'  | append: i -%}
          {%- assign img_before = section.settings[ba_before] -%}
          {%- assign img_after  = section.settings[ba_after] -%}
          {%- if img_before != blank or img_after != blank -%}
            <div class="before-after-pair-{{ section.id }}">
              <div class="before-after-item-{{ section.id }}">
                <span class="before-after-label-{{ section.id }}">before</span>
                {%- if img_before != blank -%}
                  <img
                    src="{{ img_before | image_url: width: 800 }}"
                    alt="{{ img_before.alt | default: 'Before' | escape }}"
                    loading="lazy"
                    width="800"
                    height="800"
                  >
                {%- else -%}
                  {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
              </div>
              <div class="before-after-item-{{ section.id }}">
                <span class="before-after-label-{{ section.id }}">after</span>
                {%- if img_after != blank -%}
                  <img
                    src="{{ img_after | image_url: width: 800 }}"
                    alt="{{ img_after.alt | default: 'After' | escape }}"
                    loading="lazy"
                    width="800"
                    height="800"
                  >
                {%- else -%}
                  {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const mediaContainers = document.querySelectorAll('.how-to-use-media-{{ section.id }}[data-has-video="true"]');
    
    mediaContainers.forEach(container => {
      const video = container.querySelector('video');
      if (!video) return;
      
      container.addEventListener('mouseenter', function() {
        video.play();
        container.classList.add('video-playing');
      });
      
      container.addEventListener('mouseleave', function() {
        video.pause();
        video.currentTime = 0;
        container.classList.remove('video-playing');
      });
      
      // For touch devices - tap to play/pause
      container.addEventListener('click', function() {
        if (video.paused) {
          video.play();
          container.classList.add('video-playing');
        } else {
          video.pause();
          container.classList.remove('video-playing');
        }
      });
    });
  });
</script>

{% schema %}
{
  "name": "How To Use",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "HOW TO USE:"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 12,
      "max": 48,
      "step": 1,
      "unit": "px",
      "label": "Heading size",
      "default": 18
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "min": 10,
      "max": 36,
      "step": 1,
      "unit": "px",
      "label": "Heading size - mobile",
      "default": 14
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#121212"
    },
    {
      "type": "header",
      "content": "Subheading"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading (script font)",
      "default": "Tori's Tips"
    },
    {
      "type": "range",
      "id": "subheading_size",
      "min": 16,
      "max": 72,
      "step": 1,
      "unit": "px",
      "label": "Subheading size",
      "default": 36
    },
    {
      "type": "range",
      "id": "subheading_size_mobile",
      "min": 14,
      "max": 48,
      "step": 1,
      "unit": "px",
      "label": "Subheading size - mobile",
      "default": 28
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading color",
      "default": "#121212"
    },
    {
      "type": "header",
      "content": "Step label"
    },
    {
      "type": "range",
      "id": "step_size",
      "min": 14,
      "max": 48,
      "step": 1,
      "unit": "px",
      "label": "Step label size",
      "default": 24
    },
    {
      "type": "range",
      "id": "step_size_mobile",
      "min": 12,
      "max": 36,
      "step": 1,
      "unit": "px",
      "label": "Step label size - mobile",
      "default": 18
    },
    {
      "type": "color",
      "id": "step_color",
      "label": "Step label color",
      "default": "#121212"
    },
    {
      "type": "header",
      "content": "Description text"
    },
    {
      "type": "range",
      "id": "text_size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Text size",
      "default": 13
    },
    {
      "type": "range",
      "id": "text_size_mobile",
      "min": 8,
      "max": 18,
      "step": 1,
      "unit": "px",
      "label": "Text size - mobile",
      "default": 11
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#121212"
    },
    {
      "type": "header",
      "content": "Grid settings"
    },
    {
      "type": "range",
      "id": "slider_gap",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Gap between cards",
      "default": 4
    },
    {
      "type": "range",
      "id": "slider_gap_mobile",
      "min": 0,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Gap between cards - mobile",
      "default": 2
    },
    {
      "type": "range",
      "id": "slider_mt",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Margin top",
      "default": 16
    },
    {
      "type": "header",
      "content": "Image/Video settings"
    },
    {
      "type": "range",
      "id": "image_radius",
      "min": 0,
      "max": 30,
      "step": 1,
      "unit": "px",
      "label": "Border radius",
      "default": 0
    },
    {
      "type": "range",
      "id": "image_border_thickness",
      "min": 0,
      "max": 10,
      "step": 1,
      "unit": "px",
      "label": "Border thickness",
      "default": 0
    },
    {
      "type": "color",
      "id": "image_border_color",
      "label": "Border color",
      "default": "#121212"
    },
    {
      "type": "header",
      "content": "Section colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#d4e8f2"
    },
    {
      "type": "header",
      "content": "Section margin (outside)"
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom",
      "default": 0
    },
    {
      "type": "header",
      "content": "Section padding (inside)"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "min": 0,
      "max": 10,
      "step": 0.5,
      "unit": "rem",
      "label": "Sides",
      "default": 1.5
    },
    {
      "type": "range",
      "id": "padding_horizontal_mobile",
      "min": 0,
      "max": 5,
      "step": 0.5,
      "unit": "rem",
      "label": "Sides - mobile",
      "default": 1
    },
    {
      "type": "header",
      "content": "Section"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width",
      "default": true
    },
    {
      "type": "range",
      "id": "content_width",
      "min": 800,
      "max": 2000,
      "step": 100,
      "unit": "px",
      "label": "Section content width",
      "default": 1400,
      "visible_if": "{{ section.settings.full_width == false }}"
    },
    {
      "type": "header",
      "content": "Before \/ After images"
    },
    {
      "type": "paragraph",
      "content": "Upload 3 pairs of before and after images. The grid appears below the steps."
    },
    {
      "type": "range",
      "id": "ba_mt",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Margin top",
      "default": 16
    },
    {
      "type": "range",
      "id": "ba_gap",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Gap between pairs",
      "default": 4
    },
    {
      "type": "range",
      "id": "ba_gap_mobile",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "label": "Gap between pairs - mobile",
      "default": 4
    },
    {
      "type": "range",
      "id": "ba_border_thickness",
      "min": 0,
      "max": 10,
      "step": 1,
      "unit": "px",
      "label": "Border thickness",
      "default": 1
    },
    {
      "type": "color",
      "id": "ba_border_color",
      "label": "Border color",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "ba_label_color",
      "label": "Label text color",
      "default": "#121212"
    },
    {
      "type": "header",
      "content": "Pair 1"
    },
    {
      "type": "image_picker",
      "id": "ba_before_1",
      "label": "Before image"
    },
    {
      "type": "image_picker",
      "id": "ba_after_1",
      "label": "After image"
    },
    {
      "type": "header",
      "content": "Pair 2"
    },
    {
      "type": "image_picker",
      "id": "ba_before_2",
      "label": "Before image"
    },
    {
      "type": "image_picker",
      "id": "ba_after_2",
      "label": "After image"
    },
    {
      "type": "header",
      "content": "Pair 3"
    },
    {
      "type": "image_picker",
      "id": "ba_before_3",
      "label": "Before image"
    },
    {
      "type": "image_picker",
      "id": "ba_after_3",
      "label": "After image"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "image_picker",
          "id": "poster",
          "label": "Poster image",
          "info": "This image displays first and is always visible"
        },
        {
