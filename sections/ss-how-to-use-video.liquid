{%- liquid
  assign padding_horizontal = section.settings.padding_horizontal
  assign padding_horizontal_mobile = section.settings.padding_horizontal_mobile
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign margin_top = section.settings.margin_top
  assign margin_bottom = section.settings.margin_bottom
  assign background_color = section.settings.background_color
  assign full_width = section.settings.full_width
  assign content_width = section.settings.content_width

  assign heading = section.settings.heading
  assign heading_size = section.settings.heading_size
  assign heading_size_mobile = section.settings.heading_size_mobile
  assign heading_color = section.settings.heading_color

  assign subheading = section.settings.subheading
  assign subheading_size = section.settings.subheading_size
  assign subheading_size_mobile = section.settings.subheading_size_mobile
  assign subheading_color = section.settings.subheading_color

  assign step_size = section.settings.step_size
  assign step_size_mobile = section.settings.step_size_mobile
  assign step_color = section.settings.step_color

  assign text_size = section.settings.text_size
  assign text_size_mobile = section.settings.text_size_mobile
  assign text_color = section.settings.text_color

  assign slider_gap = section.settings.slider_gap
  assign slider_gap_mobile = section.settings.slider_gap_mobile
  assign slider_mt = section.settings.slider_mt

  assign image_radius = section.settings.image_radius
  assign image_border_thickness = section.settings.image_border_thickness
  assign image_border_color = section.settings.image_border_color
-%}

{%- style -%}
  @font-face {
    font-family: 'Thursday Morning';
    src: url('{{ "ThursdayMorningMedium.woff2" | asset_url }}') format('woff2'),
         url('{{ "ThursdayMorning.woff2" | asset_url }}') format('woff2'),
         url('{{ "ThursdayMorningMedium.woff2" | asset_url }}') format('woff2');
    font-weight: normal;
    font-style: normal;
    font-display: swap;
  }

  .section-{{ section.id }} {
    margin-top: {{ margin_top | times: 0.75 | round: 0 }}px;
    margin-bottom: {{ margin_bottom | times: 0.75 | round: 0 }}px;
    background-color: {{ background_color }};
  }

  .section-{{ section.id }}-settings {
    margin: 0 auto;
    width: 100%;
    height: 100%;
    padding-top: {{ padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ padding_bottom | times: 0.75 | round: 0 }}px;
    padding-left: {{ padding_horizontal_mobile }}rem;
    padding-right: {{ padding_horizontal_mobile }}rem;
  }

  .how-to-use-header-{{ section.id }} {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin-bottom: 0;
    flex-wrap: wrap;
  }

  .how-to-use-heading-{{ section.id }} {
    margin: 0;
    font-size: {{ heading_size_mobile }}px;
    color: {{ heading_color }};
    line-height: 1.2;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-weight: 400;
    position: relative;
    padding-bottom: 0.25rem;
  }

  .how-to-use-subheading-{{ section.id }} {
    margin: 0;
    font-family: 'Thursday Morning', cursive;
    font-size: {{ subheading_size_mobile }}px;
    color: {{ subheading_color }};
    line-height: 1.2;
    font-weight: normal;
  }

  .how-to-use-underline-{{ section.id }} {
    display: block;
    width: calc(100% + 1rem);
    height: 2px;
    background-color: {{ heading_color }};
    margin-top: 0.5rem;
    margin-bottom: 0;
  }

  .how-to-use-grid-{{ section.id }} {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: {{ slider_gap_mobile }}px;
    margin-top: {{ slider_mt | times: 0.75 | round: 0 }}px;
  }

  .how-to-use-card-{{ section.id }} {
    display: flex;
    flex-direction: column;
    text-align: center;
  }

  .how-to-use-media-{{ section.id }} {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: {{ image_radius }}px;
    border: {{ image_border_thickness }}px solid {{ image_border_color }};
    background-color: #ddd;
  }

  .how-to-use-media-{{ section.id }} img,
  .how-to-use-media-{{ section.id }} video {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .how-to-use-media-{{ section.id }} video {
    position: absolute;
    top: 0;
    left: 0;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .how-to-use-media-{{ section.id }}.video-playing video {
    opacity: 1;
  }

  .how-to-use-media-{{ section.id }} .placeholder-svg {
    width: 100%;
    height: 100%;
  }

  .how-to-use-step-{{ section.id }} {
    margin: 0;
    margin-top: 12px;
    font-family: 'Thursday Morning', cursive;
    font-size: {{ step_size_mobile }}px;
    color: {{ step_color }};
    line-height: 1.3;
    font-weight: normal;
  }

  .how-to-use-text-{{ section.id }} {
    margin: 0;
    margin-top: 6px;
    font-size: {{ text_size_mobile }}px;
    color: {{ text_color }};
    line-height: 1.4;
    font-weight: 400;
  }

  @media(min-width: 768px) {
    .how-to-use-grid-{{ section.id }} {
      grid-template-columns: repeat(4, 1fr);
      gap: {{ slider_gap }}px;
      margin-top: {{ slider_mt }}px;
    }
  }

  @media(min-width: 1024px) {
    .section-{{ section.id }} {
      margin-top: {{ margin_top }}px;
      margin-bottom: {{ margin_bottom }}px;
    }

    .section-{{ section.id }}-settings {
      padding-top: {{ padding_top }}px;
      padding-bottom: {{ padding_bottom }}px;
      padding-left: {{ padding_horizontal }}rem;
      padding-right: {{ padding_horizontal }}rem;
    }

    .how-to-use-heading-{{ section.id }} {
      font-size: {{ heading_size }}px;
    }

    .how-to-use-subheading-{{ section.id }} {
      font-size: {{ subheading_size }}px;
    }

    .how-to-use-step-{{ section.id }} {
      font-size: {{ step_size }}px;
    }

    .how-to-use-text-{{ section.id }} {
      font-size: {{ text_size }}px;
    }
  }
{%- endstyle -%}

{% unless full_width %}
  <style>
    .section-{{ section.id }}-settings {
      max-width: {{ content_width }}px;
    }
  </style>
{% endunless %}

<div class="container max-w-fluid section-{{ section.id }}">
  <div class="section-{{ section.id }}-settings">
    <div class="how-to-use-header-{{ section.id }}">
      {% if heading != blank %}
        <h2 class="how-to-use-heading-{{ section.id }}">{{ heading }}</h2>
      {% endif %}
      {% if subheading != blank %}
        <span class="how-to-use-subheading-{{ section.id }}">{{ subheading }}</span>
      {% endif %}
    </div>
    <div class="how-to-use-underline-{{ section.id }}"></div>

    <div class="how-to-use-grid-{{ section.id }}">
      {% for block in section.blocks %}
        <div class="how-to-use-card-{{ section.id }}" {{ block.shopify_attributes }}>
          <div class="how-to-use-media-{{ section.id }}" data-has-video="{% if block.settings.video != blank %}true{% else %}false{% endif %}">
            {% if block.settings.poster != blank %}
              <img
                src="{{ block.settings.poster | image_url: width: 600 }}"
                alt="{{ block.settings.poster.alt | default: block.settings.step_label }}"
                loading="lazy"
                width="600"
                height="600"
              >
            {% else %}
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
            {% endif %}
            
            {% if block.settings.video != blank %}
              <video
                src="{{ block.settings.video.sources[1].url }}"
                muted
                playsinline
                loop
                preload="none"
              ></video>
            {% endif %}
          </div>
          {% if block.settings.step_label != blank %}
            <p class="how-to-use-step-{{ section.id }}">{{ block.settings.step_label }}</p>
          {% endif %}
          {% if block.settings.description != blank %}
            <p class="how-to-use-text-{{ section.id }}">{{ block.settings.description }}</p>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const mediaContainers = document.querySelectorAll('.how-to-use-media-{{ section.id }}[data-has-video="true"]');
    
    mediaContainers.forEach(container => {
      const video = container.querySelector('video');
      if (!video) return;
      
      container.addEventListener('mouseenter', function() {
        video.play();
        container.classList.add('video-playing');
      });
      
      container.addEventListener('mouseleave', function() {
        video.pause();
        video.currentTime = 0;
        container.classList.remove('video-playing');
      });
      
      // For touch devices - tap to play/pause
      container.addEventListener('click', function() {
        if (video.paused) {
          video.play();
          container.classList.add('video-playing');
        } else {
          video.pause();
          container.classList.remove('video-playing');
        }
      });
    });
  });
</script>

{% schema %}
{
  "name": "How To Use",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "HOW TO USE:"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 12,
      "max": 48,
      "step": 1,
      "unit": "px",
      "label": "Heading size",
      "default": 18
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "min": 10,
      "max": 36,
      "step": 1,
      "unit": "px",
      "label": "Heading size - mobile",
      "default": 14
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#121212"
    },
    {
      "type": "header",
      "content": "Subheading"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading (script font)",
      "default": "Tori's Tips"
    },
    {
      "type": "range",
      "id": "subheading_size",
      "min": 16,
      "max": 72,
      "step": 1,
      "unit": "px",
      "label": "Subheading size",
      "default": 36
    },
    {
      "type": "range",
      "id": "subheading_size_mobile",
      "min": 14,
      "max": 48,
      "step": 1,
      "unit": "px",
      "label": "Subheading size - mobile",
      "default": 28
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading color",
      "default": "#121212"
    },
    {
      "type": "header",
      "content": "Step label"
    },
    {
      "type": "range",
      "id": "step_size",
      "min": 14,
      "max": 48,
      "step": 1,
      "unit": "px",
      "label": "Step label size",
      "default": 24
    },
    {
      "type": "range",
      "id": "step_size_mobile",
      "min": 12,
