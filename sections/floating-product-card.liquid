{%- assign product = section.settings.product -%}

{{- 'section-floating-product-card.css' | asset_url | stylesheet_tag -}}

{%- style -%}
  #shopify-section-{{ section.id }} {
    --section-spacing-top: calc(var(--section-spacing-unit-size) * {{ section.settings.spacing_top }});
    --section-spacing-bottom: calc(var(--section-spacing-unit-size) * {{ section.settings.spacing_bottom }});
    --floating-card-position-x: {{ section.settings.card_position_horizontal }}%;
    --floating-card-position-y: {{ section.settings.card_position_vertical }}%;
    --floating-card-position-ratio: {{ section.settings.card_position_horizontal | divided_by: 100.0 }};
    --floating-card-max-width: {{ section.settings.card_max_width }}px;
    --section-min-height: {{ section.settings.section_min_height }}vh;
  }

  {% if section.settings.background_image %}
    #shopify-section-{{ section.id }} .floating-product-section__background {
      background-image: url('{{ section.settings.background_image | image_url: width: 2400 }}');
    }
  {% endif %}
{%- endstyle -%}

<div class="floating-product-section color-{{ section.settings.color_scheme }} gradient">
  <div class="floating-product-section__background{% if section.settings.background_overlay %} floating-product-section__background--overlay{% endif %}">
    {% if section.settings.background_image == blank and section.settings.background_video == blank %}
      <div class="floating-product-section__background-color"></div>
    {% endif %}

    {% if section.settings.background_video != blank %}
      <video
        class="floating-product-section__video"
        autoplay
        muted
        loop
        playsinline
      >
        <source src="{{ section.settings.background_video }}" type="video/mp4">
      </video>
    {% endif %}
  </div>

  <div class="floating-product-section__content container {{ section.settings.section_width }}">
    {% if section.settings.heading != blank %}
      <div class="floating-product-section__heading-wrapper floating-product-section__heading--{{ section.settings.heading_position }}">
        <h2 class="floating-product-section__heading {{ section.settings.heading_size }}">
          {{ section.settings.heading }}
        </h2>
        {% if section.settings.subheading != blank %}
          <p class="floating-product-section__subheading">{{ section.settings.subheading }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="floating-product-section__card-track floating-product-section__card-track--{{ section.settings.card_position }}">
      {% if product != blank %}
        <div class="floating-product-section__card-wrapper{% if section.settings.card_float_animation %} floating-product-section__card--animated{% endif %}">
          {%- render 'card-product', 
            product_ref: product, 
            section_id: section.id,
            show_variants: section.settings.show_variants,
            show_short_description: section.settings.show_description
          -%}
        </div>
      {% else %}
        <div class="floating-product-section__card-wrapper{% if section.settings.card_float_animation %} floating-product-section__card--animated{% endif %}">
          <div class="floating-product-section__placeholder">
            <div class="placeholder-card">
              <div class="placeholder-card__media">
                {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
              <div class="placeholder-card__content">
                <span class="placeholder-card__title">Product Title</span>
                <span class="placeholder-card__price">$0.00</span>
              </div>
            </div>
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Floating Product Card",
  "tag": "section",
  "class": "section-floating-product-card",
  "settings": [
    {
      "type": "header",
      "content": "Product"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "checkbox",
      "id": "show_variants",
      "label": "Show variant options",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show short description",
      "default": true
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "url",
      "id": "background_video",
      "label": "Background video URL",
      "info": "MP4 video URL for animated backgrounds"
    },
    {
      "type": "checkbox",
      "id": "background_overlay",
      "label": "Enable dark overlay",
      "default": false,
      "info": "Adds a dark overlay to improve text readability"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.global.color_scheme.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        {
          "value": "h4",
          "label": "Small"
        },
        {
          "value": "h3",
          "label": "Medium"
        },
        {
          "value": "h2",
          "label": "Large"
        },
        {
          "value": "h1",
          "label": "Extra Large"
        }
      ],
      "default": "h2"
    },
    {
      "type": "select",
      "id": "heading_position",
      "label": "Heading position",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Card Layout"
    },
    {
      "type": "select",
      "id": "card_position",
      "label": "Card position preset",
      "options": [
        {
          "value": "top-left",
          "label": "Top Left"
        },
        {
          "value": "top-center",
          "label": "Top Center"
        },
        {
          "value": "top-right",
          "label": "Top Right"
        },
        {
          "value": "center-left",
          "label": "Center Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "center-right",
          "label": "Center Right"
        },
        {
          "value": "bottom-left",
          "label": "Bottom Left"
        },
        {
          "value": "bottom-center",
          "label": "Bottom Center"
        },
        {
          "value": "bottom-right",
          "label": "Bottom Right"
        },
        {
          "value": "custom",
          "label": "Custom Position"
        }
      ],
      "default": "center-left"
    },
    {
      "type": "range",
      "id": "card_position_horizontal",
      "label": "Custom horizontal position",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 10,
      "info": "Only applies when 'Custom Position' is selected"
    },
    {
      "type": "range",
      "id": "card_position_vertical",
      "label": "Custom vertical position",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 50,
      "info": "Only applies when 'Custom Position' is selected"
    },
    {
      "type": "range",
      "id": "card_max_width",
      "label": "Card max width",
      "min": 200,
      "max": 500,
      "step": 10,
      "unit": "px",
      "default": 320
    },
    {
      "type": "checkbox",
      "id": "card_float_animation",
      "label": "Enable floating animation",
      "default": true,
      "info": "Adds a subtle floating animation to the card"
    },
    {
      "type": "header",
      "content": "Section Layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        {
          "value": "container--sm",
          "label": "Small"
        },
        {
          "value": "container--md",
          "label": "Medium"
        },
        {
          "value": "container--lg",
          "label": "Large"
        },
        {
          "value": "container--full",
          "label": "Full width"
        }
      ],
      "default": "container--lg"
    },
    {
      "type": "range",
      "id": "section_min_height",
      "label": "Minimum section height",
      "min": 30,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "default": 70
    },
    {
      "type": "range",
      "id": "spacing_top",
      "min": 0,
      "max": 6,
      "step": 1,
      "default": 2,
      "label": "t:sections.global.spacing.top.label"
    },
    {
      "type": "range",
      "id": "spacing_bottom",
      "min": 0,
      "max": 6,
      "step": 1,
      "default": 2,
      "label": "t:sections.global.spacing.bottom.label"
    }
  ],
  "presets": [
    {
      "name": "Floating Product Card",
      "settings": {
        "heading": "Featured <em>Product</em>",
        "card_position": "center-left",
        "card_float_animation": true
      }
    }
  ]
}
{% endschema %}

