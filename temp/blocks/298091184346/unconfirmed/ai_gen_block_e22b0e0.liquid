{% doc %}
  @prompt
    In the shoppable video section, disable the video from opening/playing when clicked. Only the add to cart button should be functional when users interact with the video section. Clicking on the video itself should do nothing (no modal, no video playback popup).
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-shoppable-video-{{ ai_gen_id }} {
    position: relative;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    display: block;
  }

  .ai-shoppable-video-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
  }

  .ai-shoppable-video-media-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    pointer-events: none;
  }

  .ai-shoppable-video-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-shoppable-video-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .ai-shoppable-video-hotspot-{{ ai_gen_id }} {
    position: absolute;
    z-index: 2;
  }

  .ai-shoppable-video-hotspot-button-{{ ai_gen_id }} {
    width: {{ block.settings.hotspot_size }}px;
    height: {{ block.settings.hotspot_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.hotspot_color }};
    border: 2px solid {{ block.settings.hotspot_border_color }};
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: transform 0.3s ease;
    pointer-events: auto;
  }

  .ai-shoppable-video-hotspot-button-{{ ai_gen_id }}:hover {
    transform: scale(1.1);
  }

  .ai-shoppable-video-hotspot-button-{{ ai_gen_id }} svg {
    width: calc({{ block.settings.hotspot_size }}px * 0.5);
    height: calc({{ block.settings.hotspot_size }}px * 0.5);
    stroke: {{ block.settings.hotspot_icon_color }};
  }

  .ai-shoppable-video-popup-{{ ai_gen_id }} {
    position: absolute;
    width: {{ block.settings.popup_width }}px;
    background-color: {{ block.settings.popup_bg_color }};
    border-radius: 8px;
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
    padding: 15px;
    z-index: 3;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease, transform 0.3s ease;
    pointer-events: none;
  }

  .ai-shoppable-video-popup-{{ ai_gen_id }}.active {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  .ai-shoppable-video-popup-{{ ai_gen_id }}--top {
    bottom: calc(100% + 10px);
    left: 50%;
    transform: translateX(-50%) translateY(10px);
  }

  .ai-shoppable-video-popup-{{ ai_gen_id }}--top.active {
    transform: translateX(-50%) translateY(0);
  }

  .ai-shoppable-video-popup-{{ ai_gen_id }}--bottom {
    top: calc(100% + 10px);
    left: 50%;
    transform: translateX(-50%) translateY(-10px);
  }

  .ai-shoppable-video-popup-{{ ai_gen_id }}--bottom.active {
    transform: translateX(-50%) translateY(0);
  }

  .ai-shoppable-video-popup-{{ ai_gen_id }}--left {
    right: calc(100% + 10px);
    top: 50%;
    transform: translateY(-50%) translateX(10px);
  }

  .ai-shoppable-video-popup-{{ ai_gen_id }}--left.active {
    transform: translateY(-50%) translateX(0);
  }

  .ai-shoppable-video-popup-{{ ai_gen_id }}--right {
    left: calc(100% + 10px);
    top: 50%;
    transform: translateY(-50%) translateX(-10px);
  }

  .ai-shoppable-video-popup-{{ ai_gen_id }}--right.active {
    transform: translateY(-50%) translateX(0);
  }

  .ai-shoppable-video-popup-content-{{ ai_gen_id }} {
    position: relative;
  }

  .ai-shoppable-video-popup-close-{{ ai_gen_id }} {
    position: absolute;
    top: -5px;
    right: -5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 5px;
    color: {{ block.settings.popup_text_color }};
    opacity: 0.7;
  }

  .ai-shoppable-video-popup-close-{{ ai_gen_id }}:hover {
    opacity: 1;
  }

  .ai-shoppable-video-product-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .ai-shoppable-video-product-image-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1 / 1;
    flex-shrink: 0;
  }

  .ai-shoppable-video-product-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 4px;
  }

  .ai-shoppable-video-product-info-{{ ai_gen_id }} {
    flex-grow: 1;
  }

  .ai-shoppable-video-product-title-{{ ai_gen_id }} {
    font-size: 14px;
    font-weight: 600;
    margin: 0 0 5px;
    color: {{ block.settings.popup_text_color }};
  }

  .ai-shoppable-video-product-price-{{ ai_gen_id }} {
    font-size: 14px;
    margin-bottom: 10px;
    color: {{ block.settings.popup_text_color }};
  }

  .ai-shoppable-video-add-to-cart-{{ ai_gen_id }} {
    width: 100%;
    padding: 10px 20px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: 4px;
    cursor: pointer;
    font-size: 14px;
    transition: background-color 0.3s ease;
  }

  .ai-shoppable-video-add-to-cart-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-shoppable-video-empty-product-{{ ai_gen_id }} {
    font-size: 14px;
    color: #999;
    text-align: center;
    padding: 10px;
    font-style: italic;
  }

  @media screen and (max-width: 749px) {
    .ai-shoppable-video-hotspot-button-{{ ai_gen_id }} {
      width: calc({{ block.settings.hotspot_size }}px * 0.8);
      height: calc({{ block.settings.hotspot_size }}px * 0.8);
    }

    .ai-shoppable-video-popup-{{ ai_gen_id }} {
      width: calc({{ block.settings.popup_width }}px * 0.8);
    }
  }
{% endstyle %}

<shoppable-video-{{ ai_gen_id }}
  class="ai-shoppable-video-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-shoppable-video-wrapper-{{ ai_gen_id }}">
    {% if block.settings.video %}
      <video
        class="ai-shoppable-video-media-{{ ai_gen_id }}"
        src="{{ block.settings.video | file_url }}"
        {% if block.settings.autoplay %}autoplay{% endif %}
        {% if block.settings.loop %}loop{% endif %}
        {% if block.settings.muted %}muted{% endif %}
        playsinline
      ></video>
    {% else %}
      <div class="ai-shoppable-video-placeholder-{{ ai_gen_id }}">
        {{ 'image' | placeholder_svg_tag }}
      </div>
    {% endif %}

    {% for i in (1..3) %}
      {% liquid
        assign hotspot_enabled_key = 'hotspot_' | append: i | append: '_enabled'
        assign hotspot_x_key = 'hotspot_' | append: i | append: '_x'
        assign hotspot_y_key = 'hotspot_' | append: i | append: '_y'
        assign product_key = 'hotspot_' | append: i | append: '_product'

        assign hotspot_enabled = block.settings[hotspot_enabled_key]
        assign hotspot_x = block.settings[hotspot_x_key]
        assign hotspot_y = block.settings[hotspot_y_key]
        assign product = block.settings[product_key]
      %}

      {% if hotspot_enabled %}
        <div
          class="ai-shoppable-video-hotspot-{{ ai_gen_id }}"
          style="left: {{ hotspot_x }}%; top: {{ hotspot_y }}%;"
          data-hotspot-id="{{ i }}"
        >
          <button
            class="ai-shoppable-video-hotspot-button-{{ ai_gen_id }}"
            aria-label="View product details"
            aria-expanded="false"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <line x1="12" y1="5" x2="12" y2="19"></line>
              <line x1="5" y1="12" x2="19" y2="12"></line>
            </svg>
          </button>

          <div
            class="ai-shoppable-video-popup-{{ ai_gen_id }} ai-shoppable-video-popup-{{ ai_gen_id }}--{{ block.settings.popup_position }}"
          >
            <div class="ai-shoppable-video-popup-content-{{ ai_gen_id }}">
              {% if product != blank %}
                <div class="ai-shoppable-video-product-{{ ai_gen_id }}">
                  <div class="ai-shoppable-video-product-image-{{ ai_gen_id }}">
                    {% if product.featured_image %}
                      <img
                        src="{{ product.featured_image | image_url: width: 200 }}"
                        alt="{{ product.featured_image.alt | escape }}"
                        width="200"
                        height="200"
                        loading="lazy"
                      >
                    {% endif %}
                  </div>
                  <div class="ai-shoppable-video-product-info-{{ ai_gen_id }}">
                    <h3 class="ai-shoppable-video-product-title-{{ ai_gen_id }}">{{ product.title }}</h3>
                    <div class="ai-shoppable-video-product-price-{{ ai_gen_id }}">{{ product.price | money }}</div>
                    <button
                      class="ai-shoppable-video-add-to-cart-{{ ai_gen_id }}"
                      data-product-id="{{ product.id }}"
                      data-variant-id="{{ product.selected_or_first_available_variant.id }}"
                    >
                      {{ block.settings.add_to_cart_text }}
                    </button>
                  </div>
                </div>
              {% else %}
                <div class="ai-shoppable-video-empty-product-{{ ai_gen_id }}">
                  Next, add a product for this hotspot
                </div>
              {% endif %}
              <button
                class="ai-shoppable-video-popup-close-{{ ai_gen_id }}"
                aria-label="Close"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <line x1="18" y1="6" x2="6" y2="18"></line>
                  <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
              </button>
            </div>
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</shoppable-video-{{ ai_gen_id }}>

<script>
  (function() {
    class ShoppableVideo{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.hotspots = this.querySelectorAll('.ai-shoppable-video-hotspot-{{ ai_gen_id }}');
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.hotspots.forEach((hotspot) => {
          const button = hotspot.querySelector('.ai-shoppable-video-hotspot-button-{{ ai_gen_id }}');
          const popup = hotspot.querySelector('.ai-shoppable-video-popup-{{ ai_gen_id }}');
          const closeButton = popup.querySelector('.ai-shoppable-video-popup-close-{{ ai_gen_id }}');
          const addToCartButton = popup.querySelector('.ai-shoppable-video-add-to-cart-{{ ai_gen_id }}');

          button.addEventListener('click', (e) => {
            e.stopPropagation();
            this.querySelectorAll('.ai-shoppable-video-popup-{{ ai_gen_id }}').forEach((p) => {
              if (p !== popup) {
                p.classList.remove('active');
                p.previousElementSibling.setAttribute('aria-expanded', 'false');
              }
            });

            const isActive = popup.classList.contains('active');
            popup.classList.toggle('active');
            button.setAttribute('aria-expanded', !isActive);
          });

          closeButton.addEventListener('click', (e) => {
            e.stopPropagation();
            popup.classList.remove('active');
            button.setAttribute('aria-expanded', 'false');
          });

          if (addToCartButton) {
            addToCartButton.addEventListener('click', (e) => {
              e.stopPropagation();
              const variantId = addToCartButton.dataset.variantId;
              
              fetch('/cart/add.js', {
                method: 'POST',
                headers: {
                  'Content-Type': 'application/json',
                },
                body: JSON.stringify({
                  id: variantId,
                  quantity: 1
                })
              })
              .then(response => response.json())
              .then(data => {
                window.dispatchEvent(new Event('cart:refresh'));
                popup.classList.remove('active');
                button.setAttribute('aria-expanded', 'false');
              })
              .catch((error) => {
                console.error('Error:', error);
              });
            });
          }
        });

        document.addEventListener('click', (event) => {
          if (
            !event.target.closest('.ai-shoppable-video-popup-{{ ai_gen_id }}') &&
            !event.target.closest('.ai-shoppable-video-hotspot-button-{{ ai_gen_id }}')
          ) {
            this.querySelectorAll('.ai-shoppable-video-popup-{{ ai_gen_id }}').forEach((popup) => {
              popup.classList.remove('active');
              const button = popup.previousElementSibling;
              if (button) {
                button.setAttribute('aria-expanded', 'false');
              }
            });
          }
        });
      }
    }

    customElements.define('shoppable-video-{{ ai_gen_id }}', ShoppableVideo{{ ai_gen_id }});
  })();
</script>

