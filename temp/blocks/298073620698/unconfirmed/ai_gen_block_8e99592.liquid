{% doc %}
  @prompt
    Add custom CSS to decrease the font size of just the "professional-quality" text within the Hero banner section with ID template--21566028939482__1658995208ad05f95f. Target only that specific text within that section to avoid affecting other elements on the page.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-custom-css-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
  }

  #template--21566028939482__1658995208ad05f95f {{ block.settings.target_selector }} {
    font-size: {{ block.settings.font_size }}px !important;
  }

  @media screen and (max-width: 749px) {
    #template--21566028939482__1658995208ad05f95f {{ block.settings.target_selector }} {
      font-size: {{ block.settings.mobile_font_size }}px !important;
    }
  }
{% endstyle %}

<div class="ai-custom-css-{{ ai_gen_id }}" {{ block.shopify_attributes }}></div>

{% schema %}
{
  "name": "Custom CSS for hero text",
  "settings": [
    {
      "type": "header",
      "content": "Target settings"
    },
    {
      "type": "text",
      "id": "target_selector",
      "label": "CSS selector",
      "default": "*:contains('professional-quality')",
      "info": "Enter the CSS selector to target the specific text. Examples: .class-name, #id-name, or element type"
    },
    {
      "type": "header",
      "content": "Font size"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Desktop font size",
      "min": 8,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "mobile_font_size",
      "label": "Mobile font size",
      "min": 8,
      "max": 80,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Custom CSS for hero text"
    }
  ]
}
{% endschema %}
