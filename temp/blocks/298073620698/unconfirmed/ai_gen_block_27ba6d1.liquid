{% doc %}
  @prompt
    Add custom CSS to the FAQ/Accordions section so that the first accordion question item has extra top padding or margin, preventing it from being flush against the divider line or content above it. The spacing should create visible breathing room between the top border/line and the first question.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-accordion-spacing-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-accordion-spacing-{{ ai_gen_id }} details:first-of-type {
    padding-top: {{ block.settings.top_spacing_desktop }}px;
  }

  .ai-accordion-spacing-{{ ai_gen_id }} details:first-of-type summary {
    margin-top: {{ block.settings.additional_summary_spacing }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-accordion-spacing-{{ ai_gen_id }} details:first-of-type {
      padding-top: {{ block.settings.top_spacing_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-accordion-spacing-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <style>
    {% if block.settings.target_section_class != blank %}
      .{{ block.settings.target_section_class }} details:first-of-type,
      .{{ block.settings.target_section_class }} .accordion:first-child,
      .{{ block.settings.target_section_class }} .collapsible-content:first-child {
        padding-top: {{ block.settings.top_spacing_desktop }}px !important;
      }

      @media screen and (max-width: 749px) {
        .{{ block.settings.target_section_class }} details:first-of-type,
        .{{ block.settings.target_section_class }} .accordion:first-child,
        .{{ block.settings.target_section_class }} .collapsible-content:first-child {
          padding-top: {{ block.settings.top_spacing_mobile }}px !important;
        }
      }
    {% endif %}

    {% if block.settings.apply_to_all_accordions %}
      details:first-of-type,
      .accordion:first-child,
      .collapsible-content:first-child,
      .collapsible-row:first-child {
        padding-top: {{ block.settings.top_spacing_desktop }}px !important;
      }

      @media screen and (max-width: 749px) {
        details:first-of-type,
        .accordion:first-child,
        .collapsible-content:first-child,
        .collapsible-row:first-child {
          padding-top: {{ block.settings.top_spacing_mobile }}px !important;
        }
      }
    {% endif %}
  </style>

  {% if block.settings.show_helper_text %}
    <div style="padding: 20px; background-color: {{ block.settings.helper_bg_color }}; color: {{ block.settings.helper_text_color }}; border-radius: 8px; margin: 20px 0; text-align: center;">
      <p style="margin: 0; font-size: 14px;">
        ✓ Custom spacing applied to first accordion item
        {% if block.settings.target_section_class != blank %}
          (targeting: .{{ block.settings.target_section_class }})
        {% elsif block.settings.apply_to_all_accordions %}
          (applied globally)
        {% endif %}
      </p>
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Accordion top spacing",
  "settings": [
    {
      "type": "header",
      "content": "Spacing settings"
    },
    {
      "type": "range",
      "id": "top_spacing_desktop",
      "label": "Top spacing (desktop)",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "top_spacing_mobile",
      "label": "Top spacing (mobile)",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "additional_summary_spacing",
      "label": "Extra summary spacing",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Targeting options"
    },
    {
      "type": "paragraph",
      "content": "Choose how to apply the spacing: target a specific section class or apply globally to all accordions."
    },
    {
      "type": "text",
      "id": "target_section_class",
      "label": "Target section class",
      "placeholder": "collapsible-content-wrapper"
    },
    {
      "type": "checkbox",
      "id": "apply_to_all_accordions",
      "label": "Apply to all accordions globally",
      "default": false
    },
    {
      "type": "header",
      "content": "Helper display"
    },
    {
      "type": "checkbox",
      "id": "show_helper_text",
      "label": "Show confirmation message",
      "default": true
    },
    {
      "type": "color",
      "id": "helper_bg_color",
      "label": "Helper background",
      "default": "#e6f6ff"
    },
    {
      "type": "color",
      "id": "helper_text_color",
      "label": "Helper text color",
      "default": "#151515"
    }
  ],
  "presets": [
    {
      "name": "Accordion top spacing"
    }
  ]
}
{% endschema %}