{% doc %}
  @prompt
    large text secton, too big of text. this will be a page of paragraphs
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-text-content-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-text-content__inner-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    font-family: {{ block.settings.font_family.family }}, {{ block.settings.font_family.fallback_families }};
    font-weight: {{ block.settings.font_family.weight }};
    font-style: {{ block.settings.font_family.style }};
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.font_size }}px;
    line-height: {{ block.settings.line_height }};
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-text-content__inner-{{ ai_gen_id }} p {
    margin-bottom: {{ block.settings.paragraph_spacing }}px;
  }

  .ai-text-content__inner-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  .ai-text-content__inner-{{ ai_gen_id }} h1,
  .ai-text-content__inner-{{ ai_gen_id }} h2,
  .ai-text-content__inner-{{ ai_gen_id }} h3,
  .ai-text-content__inner-{{ ai_gen_id }} h4,
  .ai-text-content__inner-{{ ai_gen_id }} h5,
  .ai-text-content__inner-{{ ai_gen_id }} h6 {
    margin-bottom: {{ block.settings.heading_spacing }}px;
    color: {{ block.settings.heading_color }};
  }

  .ai-text-content__inner-{{ ai_gen_id }} ul,
  .ai-text-content__inner-{{ ai_gen_id }} ol {
    margin-bottom: {{ block.settings.paragraph_spacing }}px;
    padding-left: 20px;
  }

  .ai-text-content__inner-{{ ai_gen_id }} li {
    margin-bottom: 8px;
  }

  @media screen and (max-width: 749px) {
    .ai-text-content__inner-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.font_size }}px * 0.9);
    }
  }
{% endstyle %}

<div class="ai-text-content-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.text != blank %}
    <div class="ai-text-content__inner-{{ ai_gen_id }}">
      {{ block.settings.text }}
    </div>
  {% else %}
    <div class="ai-text-content__inner-{{ ai_gen_id }}" style="color: #999;">
      Add your text content here
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Text content",
  "settings": [
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Add your paragraphs and content here. This block is designed for longer text sections with multiple paragraphs.</p>"
    },
    {
      "type": "font_picker",
      "id": "font_family",
      "label": "Font",
      "default": "bricolage_grotesque_n4"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "line_height",
      "label": "Line height",
      "min": 1.2,
      "max": 2,
      "step": 0.1,
      "default": 1.6
    },
    {
      "type": "range",
      "id": "paragraph_spacing",
      "label": "Paragraph spacing",
      "min": 8,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "heading_spacing",
      "label": "Heading spacing",
      "min": 8,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max width",
      "min": 400,
      "max": 1200,
      "step": 100,
      "unit": "px",
      "default": 800
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#151515"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Headings",
      "default": "#151515"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Horizontal padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "Text content"
    }
  ]
}
{% endschema %}
