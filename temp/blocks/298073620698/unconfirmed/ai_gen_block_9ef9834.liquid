{% doc %}
  @prompt
    Add custom CSS to reduce the spacing/margin between the "FANSĒ SEEING YOU HERE!" heading and the text below it in the section with ID template--21566028939482__1658995208ad05f95f. Target the specific section to avoid affecting other sections on the page.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-custom-css-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  #template--21566028939482__1658995208ad05f95f .rich-text__heading {
    margin-bottom: {{ block.settings.heading_bottom_margin }}px !important;
  }

  #template--21566028939482__1658995208ad05f95f .rich-text__text {
    margin-top: {{ block.settings.text_top_margin }}px !important;
  }
{% endstyle %}

<div class="ai-custom-css-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <p style="text-align: center; color: {{ block.settings.message_color }}; font-size: {{ block.settings.message_size }}px;">
    {{ block.settings.message_text }}
  </p>
</div>

{% schema %}
{
  "name": "Custom spacing CSS",
  "settings": [
    {
      "type": "header",
      "content": "Spacing adjustments"
    },
    {
      "type": "range",
      "id": "heading_bottom_margin",
      "label": "Heading bottom margin",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 5
    },
    {
      "type": "range",
      "id": "text_top_margin",
      "label": "Text top margin",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Optional message"
    },
    {
      "type": "text",
      "id": "message_text",
      "label": "Message text",
      "default": "Custom spacing applied"
    },
    {
      "type": "range",
      "id": "message_size",
      "label": "Message size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "color",
      "id": "message_color",
      "label": "Message color",
      "default": "#65706e"
    }
  ],
  "presets": [
    {
      "name": "Custom spacing CSS"
    }
  ]
}
{% endschema %}
