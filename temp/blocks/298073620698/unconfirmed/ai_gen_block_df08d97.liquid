{% doc %}
  @prompt
    large text secton
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-large-text-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-large-text__content-{{ ai_gen_id }} {
    font-size: {{ block.settings.font_size }}px;
    line-height: {{ block.settings.line_height }};
    color: {{ block.settings.text_color }};
    font-family: {{ block.settings.font_family.family }}, {{ block.settings.font_family.fallback_families }};
    font-weight: {{ block.settings.font_family.weight }};
    font-style: {{ block.settings.font_family.style }};
    letter-spacing: {{ block.settings.letter_spacing }}em;
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  @media screen and (max-width: 749px) {
    .ai-large-text__content-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.font_size }}px * 0.7);
    }
  }
{% endstyle %}

<div class="ai-large-text-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.text != blank %}
    <div class="ai-large-text__content-{{ ai_gen_id }}">
      {{ block.settings.text }}
    </div>
  {% else %}
    <div class="ai-large-text__content-{{ ai_gen_id }}" style="color: #999;">
      Add your large text here
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Large text",
  "settings": [
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Make a bold statement with large, impactful text</p>"
    },
    {
      "type": "font_picker",
      "id": "font_family",
      "label": "Font",
      "default": "poppins_n7"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 20,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "line_height",
      "label": "Line height",
      "min": 1,
      "max": 2,
      "step": 0.1,
      "default": 1.2
    },
    {
      "type": "range",
      "id": "letter_spacing",
      "label": "Letter spacing",
      "min": -0.1,
      "max": 0.2,
      "step": 0.1,
      "default": 0
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max width",
      "min": 400,
      "max": 1200,
      "step": 100,
      "unit": "px",
      "default": 900
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#151515"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Horizontal padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "Large text"
    }
  ]
}
{% endschema %}
