{% doc %}
  @prompt
    Add custom CSS to the FAQ/Accordions section so that the first accordion question item has extra top padding or margin, preventing it from being flush against the divider line or content above it. The spacing should create visible breathing room between the top border/line and the first question.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-faq-accordion-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-faq-accordion__container-{{ ai_gen_id }} {
    border-top: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
  }

  .ai-faq-accordion__item-{{ ai_gen_id }} {
    border-bottom: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
  }

  .ai-faq-accordion__item-{{ ai_gen_id }}:first-child {
    padding-top: {{ block.settings.first_item_top_spacing }}px;
  }

  .ai-faq-accordion__button-{{ ai_gen_id }} {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: {{ block.settings.item_padding }}px 0;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    gap: 16px;
  }

  .ai-faq-accordion__question-{{ ai_gen_id }} {
    font-size: {{ block.settings.question_font_size }}px;
    font-weight: {{ block.settings.question_font_weight }};
    color: {{ block.settings.question_color }};
    margin: 0;
    flex: 1;
  }

  .ai-faq-accordion__icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    flex-shrink: 0;
    transition: transform 0.3s ease;
    color: {{ block.settings.icon_color }};
  }

  .ai-faq-accordion__button-{{ ai_gen_id }}[aria-expanded="true"] .ai-faq-accordion__icon-{{ ai_gen_id }} {
    transform: rotate(180deg);
  }

  .ai-faq-accordion__answer-{{ ai_gen_id }} {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }

  .ai-faq-accordion__answer-content-{{ ai_gen_id }} {
    padding-bottom: {{ block.settings.item_padding }}px;
    color: {{ block.settings.answer_color }};
    font-size: {{ block.settings.answer_font_size }}px;
    line-height: 1.6;
  }

  .ai-faq-accordion__answer-content-{{ ai_gen_id }} p {
    margin: 0 0 12px 0;
  }

  .ai-faq-accordion__answer-content-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-faq-accordion__question-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.question_font_size }}px * 0.9);
    }

    .ai-faq-accordion__answer-content-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.answer_font_size }}px * 0.9);
    }
  }
{% endstyle %}

<faq-accordion-{{ ai_gen_id }} class="ai-faq-accordion-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-faq-accordion__container-{{ ai_gen_id }}">
    {% if block.settings.faq_item_1_question != blank %}
      <div class="ai-faq-accordion__item-{{ ai_gen_id }}">
        <button
          class="ai-faq-accordion__button-{{ ai_gen_id }}"
          aria-expanded="false"
          aria-controls="ai-faq-answer-{{ ai_gen_id }}-1"
        >
          <h3 class="ai-faq-accordion__question-{{ ai_gen_id }}">{{ block.settings.faq_item_1_question }}</h3>
          <svg class="ai-faq-accordion__icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </button>
        <div class="ai-faq-accordion__answer-{{ ai_gen_id }}" id="ai-faq-answer-{{ ai_gen_id }}-1">
          <div class="ai-faq-accordion__answer-content-{{ ai_gen_id }}">
            {{ block.settings.faq_item_1_answer }}
          </div>
        </div>
      </div>
    {% endif %}

    {% if block.settings.faq_item_2_question != blank %}
      <div class="ai-faq-accordion__item-{{ ai_gen_id }}">
        <button
          class="ai-faq-accordion__button-{{ ai_gen_id }}"
          aria-expanded="false"
          aria-controls="ai-faq-answer-{{ ai_gen_id }}-2"
        >
          <h3 class="ai-faq-accordion__question-{{ ai_gen_id }}">{{ block.settings.faq_item_2_question }}</h3>
          <svg class="ai-faq-accordion__icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </button>
        <div class="ai-faq-accordion__answer-{{ ai_gen_id }}" id="ai-faq-answer-{{ ai_gen_id }}-2">
          <div class="ai-faq-accordion__answer-content-{{ ai_gen_id }}">
            {{ block.settings.faq_item_2_answer }}
          </div>
        </div>
      </div>
    {% endif %}

    {% if block.settings.faq_item_3_question != blank %}
      <div class="ai-faq-accordion__item-{{ ai_gen_id }}">
        <button
          class="ai-faq-accordion__button-{{ ai_gen_id }}"
          aria-expanded="false"
          aria-controls="ai-faq-answer-{{ ai_gen_id }}-3"
        >
          <h3 class="ai-faq-accordion__question-{{ ai_gen_id }}">{{ block.settings.faq_item_3_question }}</h3>
          <svg class="ai-faq-accordion__icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </button>
        <div class="ai-faq-accordion__answer-{{ ai_gen_id }}" id="ai-faq-answer-{{ ai_gen_id }}-3">
          <div class="ai-faq-accordion__answer-content-{{ ai_gen_id }}">
            {{ block.settings.faq_item_3_answer }}
          </div>
        </div>
      </div>
    {% endif %}

    {% if block.settings.faq_item_4_question != blank %}
      <div class="ai-faq-accordion__item-{{ ai_gen_id }}">
        <button
          class="ai-faq-accordion__button-{{ ai_gen_id }}"
          aria-expanded="false"
          aria-controls="ai-faq-answer-{{ ai_gen_id }}-4"
        >
          <h3 class="ai-faq-accordion__question-{{ ai_gen_id }}">{{ block.settings.faq_item_4_question }}</h3>
          <svg class="ai-faq-accordion__icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </button>
        <div class="ai-faq-accordion__answer-{{ ai_gen_id }}" id="ai-faq-answer-{{ ai_gen_id }}-4">
          <div class="ai-faq-accordion__answer-content-{{ ai_gen_id }}">
            {{ block.settings.faq_item_4_answer }}
          </div>
        </div>
      </div>
    {% endif %}

    {% if block.settings.faq_item_5_question != blank %}
      <div class="ai-faq-accordion__item-{{ ai_gen_id }}">
        <button
          class="ai-faq-accordion__button-{{ ai_gen_id }}"
          aria-expanded="false"
          aria-controls="ai-faq-answer-{{ ai_gen_id }}-5"
        >
          <h3 class="ai-faq-accordion__question-{{ ai_gen_id }}">{{ block.settings.faq_item_5_question }}</h3>
          <svg class="ai-faq-accordion__icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </button>
        <div class="ai-faq-accordion__answer-{{ ai_gen_id }}" id="ai-faq-answer-{{ ai_gen_id }}-5">
          <div class="ai-faq-accordion__answer-content-{{ ai_gen_id }}">
            {{ block.settings.faq_item_5_answer }}
          </div>
        </div>
      </div>
    {% endif %}
  </div>
</faq-accordion-{{ ai_gen_id }}>

<script>
  (function() {
    class FaqAccordion{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.buttons = this.querySelectorAll('.ai-faq-accordion__button-{{ ai_gen_id }}');
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.buttons.forEach((button) => {
          button.addEventListener('click', () => {
            const isExpanded = button.getAttribute('aria-expanded') === 'true';
            const answerId = button.getAttribute('aria-controls');
            const answer = document.getElementById(answerId);

            if (isExpanded) {
              button.setAttribute('aria-expanded', 'false');
              answer.style.maxHeight = '0';
            } else {
              button.setAttribute('aria-expanded', 'true');
              answer.style.maxHeight = answer.scrollHeight + 'px';
            }
          });
        });
      }
    }

    customElements.define('faq-accordion-{{ ai_gen_id }}', FaqAccordion{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "FAQ accordion",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "first_item_top_spacing",
      "label": "First item top spacing",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "item_padding",
      "label": "Item padding",
      "min": 8,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Question style"
    },
    {
      "type": "range",
      "id": "question_font_size",
      "label": "Font size",
      "min": 14,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "select",
      "id": "question_font_weight",
      "label": "Font weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semibold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "600"
    },
    {
      "type": "color",
      "id": "question_color",
      "label": "Color",
      "default": "#151515"
    },
    {
      "type": "header",
      "content": "Answer style"
    },
    {
      "type": "range",
      "id": "answer_font_size",
      "label": "Font size",
      "min": 12,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "answer_color",
      "label": "Color",
      "default": "#65706e"
    },
    {
      "type": "header",
      "content": "Icon"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size",
      "min": 16,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#151515"
    },
    {
      "type": "header",
      "content": "Borders"
    },
    {
      "type": "range",
      "id": "border_width",
      "label": "Border width",
      "min": 0,
      "max": 4,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#ebebeb"
    },
    {
      "type": "header",
      "content": "FAQ item 1"
    },
    {
      "type": "text",
      "id": "faq_item_1_question",
      "label": "Question",
      "default": "What is your return policy?"
    },
    {
      "type": "richtext",
      "id": "faq_item_1_answer",
      "label": "Answer",
      "default": "<p>We offer a 30-day return policy on all items. Products must be in original condition with tags attached.</p>"
    },
    {
      "type": "header",
      "content": "FAQ item 2"
    },
    {
      "type": "text",
      "id": "faq_item_2_question",
      "label": "Question",
      "default": "How long does shipping take?"
    },
    {
      "type": "richtext",
      "id": "faq_item_2_answer",
      "label": "Answer",
      "default": "<p>Standard shipping takes 5-7 business days. Express shipping is available for 2-3 business days delivery.</p>"
    },
    {
      "type": "header",
      "content": "FAQ item 3"
    },
    {
      "type": "text",
      "id": "faq_item_3_question",
      "label": "Question",
      "default": "Do you ship internationally?"
    },
    {
      "type": "richtext",
      "id": "faq_item_3_answer",
      "label": "Answer",
      "default": "<p>Yes, we ship to most countries worldwide. International shipping times vary by location.</p>"
    },
    {
      "type": "header",
      "content": "FAQ item 4"
    },
    {
      "type": "text",
      "id": "faq_item_4_question",
      "label": "Question"
    },
    {
      "type": "richtext",
      "id": "faq_item_4_answer",
      "label": "Answer"
    },
    {
      "type": "header",
      "content": "FAQ item 5"
    },
    {
      "type": "text",
      "id": "faq_item_5_question",
      "label": "Question"
    },
    {
      "type": "richtext",
      "id": "faq_item_5_answer",
      "label": "Answer"
    }
