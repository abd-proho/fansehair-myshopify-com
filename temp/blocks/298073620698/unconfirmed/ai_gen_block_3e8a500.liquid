{% doc %}
  @prompt
    Add custom CSS to decrease the font size of just the "professional-quality" text within the Hero banner section with ID template--21566028939482__1658995208ad05f95f. Target only that specific text within that section to avoid affecting other elements on the page.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% if block.settings.custom_css != blank %}
  {% style %}
    {{ block.settings.custom_css }}
  {% endstyle %}
{% endif %}

<div class="ai-custom-css-block-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.show_note %}
    <div class="ai-custom-css-note-{{ ai_gen_id }}">
      <p>{{ block.settings.note_text }}</p>
    </div>
  {% endif %}
</div>

{% style %}
  .ai-custom-css-block-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-custom-css-note-{{ ai_gen_id }} {
    padding: 20px;
    background-color: {{ block.settings.note_background_color }};
    border-radius: 8px;
    text-align: center;
  }

  .ai-custom-css-note-{{ ai_gen_id }} p {
    margin: 0;
    color: {{ block.settings.note_text_color }};
    font-size: 14px;
  }
{% endstyle %}

{% schema %}
{
  "name": "Custom CSS",
  "settings": [
    {
      "type": "header",
      "content": "Custom CSS"
    },
    {
      "type": "html",
      "id": "custom_css",
      "label": "CSS code"
    },
    {
      "type": "paragraph",
      "content": "Add your custom CSS here. For example, to target a specific section: #template--21566028939482__1658995208ad05f95f .your-class { font-size: 14px; }"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Optional note"
    },
    {
      "type": "checkbox",
      "id": "show_note",
      "label": "Show note",
      "default": false
    },
    {
      "type": "text",
      "id": "note_text",
      "label": "Note text",
      "default": "Custom CSS applied"
    },
    {
      "type": "color",
      "id": "note_background_color",
      "label": "Note background",
      "default": "#f4f4f4"
    },
    {
      "type": "color",
      "id": "note_text_color",
      "label": "Note text color",
      "default": "#151515"
    }
  ],
  "presets": [
    {
      "name": "Custom CSS"
    }
  ]
}
{% endschema %}
