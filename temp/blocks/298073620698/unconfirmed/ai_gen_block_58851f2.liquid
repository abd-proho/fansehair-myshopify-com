{% doc %}
  @prompt
    Add custom CSS to the FAQ/Accordions section so that the first accordion question item has extra top padding or margin, preventing it from being flush against the divider line or content above it. The spacing should create visible breathing room between the top border/line and the first question.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-faq-accordion-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-faq-accordion__container-{{ ai_gen_id }} {
    border-top: {{ block.settings.divider_thickness }}px solid {{ block.settings.divider_color }};
  }

  .ai-faq-accordion__item-{{ ai_gen_id }} {
    border-bottom: {{ block.settings.divider_thickness }}px solid {{ block.settings.divider_color }};
  }

  .ai-faq-accordion__item-{{ ai_gen_id }}:first-child {
    padding-top: {{ block.settings.first_item_top_spacing }}px;
  }

  .ai-faq-accordion__button-{{ ai_gen_id }} {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: {{ block.settings.item_padding }}px 0;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    gap: 16px;
  }

  .ai-faq-accordion__question-{{ ai_gen_id }} {
    font-size: {{ block.settings.question_font_size }}px;
    font-weight: {{ block.settings.question_font_weight }};
    color: {{ block.settings.question_color }};
    margin: 0;
    flex: 1;
  }

  .ai-faq-accordion__icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    flex-shrink: 0;
    transition: transform 0.3s ease;
  }

  .ai-faq-accordion__icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    stroke: {{ block.settings.icon_color }};
  }

  .ai-faq-accordion__button-{{ ai_gen_id }}[aria-expanded="true"] .ai-faq-accordion__icon-{{ ai_gen_id }} {
    transform: rotate(180deg);
  }

  .ai-faq-accordion__content-{{ ai_gen_id }} {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }

  .ai-faq-accordion__content-{{ ai_gen_id }}.active {
    max-height: 1000px;
  }

  .ai-faq-accordion__answer-{{ ai_gen_id }} {
    padding-bottom: {{ block.settings.item_padding }}px;
    font-size: {{ block.settings.answer_font_size }}px;
    color: {{ block.settings.answer_color }};
    line-height: 1.6;
  }

  @media screen and (max-width: 749px) {
    .ai-faq-accordion__question-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.question_font_size }}px * 0.9);
    }

    .ai-faq-accordion__answer-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.answer_font_size }}px * 0.9);
    }
  }
{% endstyle %}

<faq-accordion-{{ ai_gen_id }} class="ai-faq-accordion-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-faq-accordion__container-{{ ai_gen_id }}">
    {% for i in (1..5) %}
      {% liquid
        assign question_key = 'question_' | append: i
        assign answer_key = 'answer_' | append: i
        assign question = block.settings[question_key]
        assign answer = block.settings[answer_key]
      %}

      {% if question != blank and answer != blank %}
        <div class="ai-faq-accordion__item-{{ ai_gen_id }}">
          <button
            class="ai-faq-accordion__button-{{ ai_gen_id }}"
            aria-expanded="false"
            aria-controls="ai-faq-content-{{ ai_gen_id }}-{{ i }}"
          >
            <h3 class="ai-faq-accordion__question-{{ ai_gen_id }}">{{ question }}</h3>
            <span class="ai-faq-accordion__icon-{{ ai_gen_id }}">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="6 9 12 15 18 9"></polyline>
              </svg>
            </span>
          </button>
          <div
            class="ai-faq-accordion__content-{{ ai_gen_id }}"
            id="ai-faq-content-{{ ai_gen_id }}-{{ i }}"
          >
            <div class="ai-faq-accordion__answer-{{ ai_gen_id }}">
              {{ answer }}
            </div>
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</faq-accordion-{{ ai_gen_id }}>

<script>
  (function() {
    class FaqAccordion{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.buttons = this.querySelectorAll('.ai-faq-accordion__button-{{ ai_gen_id }}');
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.buttons.forEach((button) => {
          button.addEventListener('click', () => {
            const content = button.nextElementSibling;
            const isExpanded = button.getAttribute('aria-expanded') === 'true';

            button.setAttribute('aria-expanded', !isExpanded);
            content.classList.toggle('active');
          });
        });
      }
    }

    customElements.define('faq-accordion-{{ ai_gen_id }}', FaqAccordion{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "FAQ accordion",
  "settings": [
    {
      "type": "header",
      "content": "Questions and answers"
    },
    {
      "type": "text",
      "id": "question_1",
      "label": "Question 1",
      "default": "What is your return policy?"
    },
    {
      "type": "richtext",
      "id": "answer_1",
      "label": "Answer 1",
      "default": "<p>We offer a 30-day return policy on all items. Products must be in original condition with tags attached.</p>"
    },
    {
      "type": "text",
      "id": "question_2",
      "label": "Question 2",
      "default": "How long does shipping take?"
    },
    {
      "type": "richtext",
      "id": "answer_2",
      "label": "Answer 2",
      "default": "<p>Standard shipping takes 5-7 business days. Express shipping options are available at checkout.</p>"
    },
    {
      "type": "text",
      "id": "question_3",
      "label": "Question 3",
      "default": "Do you ship internationally?"
    },
    {
      "type": "richtext",
      "id": "answer_3",
      "label": "Answer 3",
      "default": "<p>Yes, we ship to most countries worldwide. Shipping costs and delivery times vary by location.</p>"
    },
    {
      "type": "text",
      "id": "question_4",
      "label": "Question 4"
    },
    {
      "type": "richtext",
      "id": "answer_4",
      "label": "Answer 4"
    },
    {
      "type": "text",
      "id": "question_5",
      "label": "Question 5"
    },
    {
      "type": "richtext",
      "id": "answer_5",
      "label": "Answer 5"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "first_item_top_spacing",
      "label": "First item top spacing",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "item_padding",
      "label": "Item padding",
      "min": 8,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Question style"
    },
    {
      "type": "range",
      "id": "question_font_size",
      "label": "Font size",
      "min": 14,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "select",
      "id": "question_font_weight",
      "label": "Font weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi-bold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "600"
    },
    {
      "type": "color",
      "id": "question_color",
      "label": "Color",
      "default": "#151515"
    },
    {
      "type": "header",
      "content": "Answer style"
    },
    {
      "type": "range",
      "id": "answer_font_size",
      "label": "Font size",
      "min": 12,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "answer_color",
      "label": "Color",
      "default": "#65706e"
    },
    {
      "type": "header",
      "content": "Divider"
    },
    {
      "type": "range",
      "id": "divider_thickness",
      "label": "Thickness",
      "min": 1,
      "max": 4,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Color",
      "default": "#ebebeb"
    },
    {
      "type": "header",
      "content": "Icon"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Size",
      "min": 16,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Color",
      "default": "#151515"
    }
  ],
  "presets": [
    {
      "name": "FAQ accordion"
    }
  ]
}
{% endschema %}
